# /* Navbar */

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #0f172a;
  padding: 15px 40px;
}

.logo h2 {
  color: white;
}

.nav-links {
  display: flex;
  gap: 20px;
  list-style: none;
}

.nav-links a {
  text-decoration: none;
  color: white;
  font-weight: 500;
}

.nav-links a:hover {
  color: #38bdf8;
}

/* Footer */

.footer {
  background: #0f172a;
  color: white;
  text-align: center;
  padding: 20px;
  margin-top: 50px;
}

/* Product Card */

.product-card {
  background: white;
  border-radius: 12px;
  padding: 15px;
  box-shadow: 0 3px 12px rgba(0,0,0,0.1);
  transition: 0.3s;
}

.product-card:hover {
  transform: translateY(-5px);
}

.product-image {
  width: 100%;
  height: 220px;
  object-fit: contain;
}

.product-card h3 {
  font-size: 16px;
  margin: 10px 0;
}

.price {
  color: green;
  font-weight: bold;
}

.btn-group {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.btn-group button {
  flex: 1;
  padding: 10px;
  border: none;
  cursor: pointer;
  background: #2563eb;
  color: white;
  border-radius: 8px;
}

.btn-group button:hover {
  background: #1d4ed8;
}

/* Search */

.search-container {
  margin: 20px 0;
}

.search-container input {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #ccc;
}

/* Loader */

.loader-container {
  text-align: center;
  padding: 50px;
}

.loader {
  width: 50px;
  height: 50px;
  border: 5px solid #ddd;
  border-top: 5px solid #2563eb;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: auto;
}

@keyframes spin {
  100% {
    transform: rotate(360deg);
  }
}